  _player: {fileID: 2140425452}
  hasDialogues: 1
  startDialogueLines:
  - "Jefe: \xA1Ov\xE1n, nos han llamado desde la Pascuala, dale que esa carne de
    caballo no se va a mover sola!"
  - "Jefe: Haz el favor de llevarla hasta la esquina, \xBFquieres?"
  - "Ov\xE1n: Si que est\xE1s mand\xF3n jefe... En fin, a mover cajas."
  endDialogueLines:
  - "Ov\xE1n: Pues ya estar\xEDa, otro duro d\xEDa de trabajo."
  - "Ov\xE1n: ..................................."
  - "Ov\xE1n: Che, a ver si me sirven un buen chivito como propina por el trabajo."
  nextScene: Nivel02
